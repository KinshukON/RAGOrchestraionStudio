# RAG Studio – Environment Variables
# Copy to .env and fill in real values.
# The app runs in simulation mode for any key left blank.

# ── Database ─────────────────────────────────────────────────────────────────
# Full Postgres URL (also used as pgvector source when PGVECTOR_URL is not set)
DATABASE_URL=postgresql://user:password@localhost:5432/rag_studio

# ── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
SECRET_KEY=change-me-with-a-long-random-string

# ── LLM – OpenAI ─────────────────────────────────────────────────────────────
# Required for: vector, hybrid, temporal, custom architecture RAG paths
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── LLM – Anthropic ──────────────────────────────────────────────────────────
# Required for: vectorless and graph architecture RAG paths
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Reranker – Cohere ────────────────────────────────────────────────────────
# Optional: improves retrieval quality. Falls back to original ranking if absent.
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Vector DB – pgvector ─────────────────────────────────────────────────────
# Defaults to DATABASE_URL if not set. Set separately if using a dedicated vector DB host.
PGVECTOR_URL=postgresql://user:password@localhost:5432/rag_studio
PGVECTOR_COLLECTION=rag_documents

# ── Graph DB – Neo4j ─────────────────────────────────────────────────────────
# Required for: graph, hybrid architecture RAG paths
NEO4J_URL=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ── Lexical / Keyword Search – Elasticsearch ─────────────────────────────────
# Optional: powers lexical retrieval leg in hybrid architecture
ELASTICSEARCH_URL=https://your-cluster.es.io:9200
ELASTICSEARCH_INDEX=rag_documents

# ── RAG Tuning ───────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MAX_CONTEXT_TOKENS=4000
